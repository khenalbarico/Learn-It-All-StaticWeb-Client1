@inherits LayoutComponentBase
@inject IAdSenseCfg AdCfg
@inject AuthSessionState AuthState
@inject NavigationManager Nav

<NavMenu />

<AdUnit SlotId="@AdCfg.TopBannerSlotId" CssClass="ad-top-banner" />

<main>
    @Body
</main>

<Footer />

@if (!IsAuthCallbackRoute)
{
    <SignInModal />
    <ProfileSetupModal />
}

@code {
    private bool IsAuthCallbackRoute
        => Nav.ToBaseRelativePath(Nav.Uri).StartsWith("authentication", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        if (!AuthState.IsBusy && !AuthState.IsAuthenticated && !IsAuthCallbackRoute)
            AuthState.OpenSignInModal();
    }
}
