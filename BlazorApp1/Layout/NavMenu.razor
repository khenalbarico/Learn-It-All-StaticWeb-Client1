@implements IDisposable
@inject AuthSessionState AuthState
@inject NavigationManager Nav

<nav class="nav-bar">
    <div class="nav-inner">
        <a class="nav-brand" href="/">
            <img src="imgs/app_logo.png" alt="Learn It All" />
            <span>Learn It All</span>
        </a>

        @if (ShowFullNav)
        {
            <button class="nav-burger" @onclick="ToggleMenu" aria-label="Toggle navigation menu">
                <span class="icon-spin-in" @key="_menuOpen">
                    <Icon Name="@(_menuOpen ? "close" : "menu")" Size="24" />
                </span>
            </button>

            <div class="nav-links @(_menuOpen ? "open" : "")">
                <NavLink href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">Home</NavLink>
                <NavLink href="/library" @onclick="CloseMenu">Library</NavLink>
                <NavLink href="/my-library" @onclick="CloseMenu">My Library</NavLink>
                <NavLink href="/account" @onclick="CloseMenu">Account</NavLink>

                <div class="nav-actions">
                    <ThemeToggle />
                    <button class="btn btn-ghost nav-cart-btn" @onclick="OpenCart" aria-label="View cart" title="Cart">
                        <Icon Name="cart" Size="20" />
                        @if (CartCount > 0)
                        {
                            <span class="cart-badge">@CartCount</span>
                        }
                    </button>
                    <button class="btn btn-secondary" @onclick="SignOut" disabled="@_guard.IsBusy">
                        <Icon Name="logout" Size="16" />
                        Log Out@(string.IsNullOrWhiteSpace(AuthState.CurrentUser?.FirstName) ? "" : $" ({AuthState.CurrentUser!.FirstName})")
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="nav-actions nav-actions-slim">
                <ThemeToggle />
                @if (AuthState.IsBusy)
                {
                    <span class="nav-spinner" aria-label="Signing in"></span>
                }
                else if (AuthState.IsAuthenticated)
                {
                    <button class="btn btn-secondary" @onclick="SignOut" disabled="@_guard.IsBusy">
                        <Icon Name="logout" Size="16" />
                        Log Out
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="AuthState.OpenSignInModal">
                        <Icon Name="user" Size="16" />
                        Log In
                    </button>
                }
            </div>
        }
    </div>
</nav>

<CartDrawer @bind-IsOpen="_cartOpen" />

@code {
    private bool _menuOpen;
    private bool _cartOpen;
    private readonly SubmitGuard _guard = new();

    private int CartCount => AuthState.CurrentUser?.Cart.Count ?? 0;

    private bool ShowFullNav
        => !AuthState.IsBusy && AuthState.IsAuthenticated && !AuthState.NeedsProfileSetup && AuthState.ProfileLoadError is null;

    protected override void OnInitialized()
    {
        AuthState.OnChange += StateHasChanged;
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private void CloseMenu() => _menuOpen = false;

    private void OpenCart()
    {
        CloseMenu();
        _cartOpen = true;
    }

    private Task SignOut() => _guard.RunAsync(async () =>
    {
        CloseMenu();
        await AuthState.SignOutAsync();
        Nav.NavigateTo("/");
    });

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }
}
