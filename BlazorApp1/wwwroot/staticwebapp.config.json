{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_framework/*", "/css/*", "/imgs/*", "/js/*", "/data/*", "/*.{png,ico,txt,json,webmanifest}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache"
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
