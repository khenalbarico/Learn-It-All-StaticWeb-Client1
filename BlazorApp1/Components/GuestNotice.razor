@inject AuthSessionState AuthState

<div class="centered-notice card">
    <div class="icon-badge">
        <Icon Name="lock" Size="28" />
    </div>
    <h2>@Title</h2>
    <p class="form-hint">@Message</p>
    <button class="btn btn-primary" @onclick="AuthState.OpenSignInModal">
        <Icon Name="user" Size="16" />
        Log In / Register
    </button>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Authenticate to access this view";
    [Parameter] public string Message { get; set; } = "Sign in or create a free account to continue.";
}
