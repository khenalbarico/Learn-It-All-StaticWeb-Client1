<div class="password-hints">
    <span class="password-hint @(HasMinLength ? "met" : "")">
        <Icon Name="check" Size="12" />
        At least 8 characters
    </span>
    <span class="password-hint @(HasUpper ? "met" : "")">
        <Icon Name="check" Size="12" />
        One uppercase letter
    </span>
    <span class="password-hint @(HasLower ? "met" : "")">
        <Icon Name="check" Size="12" />
        One lowercase letter
    </span>
    <span class="password-hint @(HasDigit ? "met" : "")">
        <Icon Name="check" Size="12" />
        One number
    </span>
</div>

@code {
    [Parameter] public string Password { get; set; } = "";

    private bool HasMinLength => Password.Length >= 8;
    private bool HasUpper => Password.Any(char.IsUpper);
    private bool HasLower => Password.Any(char.IsLower);
    private bool HasDigit => Password.Any(char.IsDigit);
}
