<div class="tabs">
    @foreach (var (value, label) in Categories)
    {
        <button class="tab-button @(value == SelectedCategory ? "active" : "")"
                @onclick="() => SelectAsync(value)"
                disabled="@IsBusy">
            @label
        </button>
    }
</div>

@code {
    [Parameter] public List<(string Value, string Label)> Categories { get; set; } = [];
    [Parameter] public string SelectedCategory { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedCategoryChanged { get; set; }
    [Parameter] public bool IsBusy { get; set; }

    private async Task SelectAsync(string value)
    {
        if (value == SelectedCategory) return;
        SelectedCategory = value;
        await SelectedCategoryChanged.InvokeAsync(value);
    }
}
