<div class="book-card" @onclick="() => OnActionClick.InvokeAsync()">
    <div class="book-card-cover-wrap">
        <img class="book-card-cover" src="@_resolvedCover" alt="@Title cover" @onerror="OnImageError" />
        @if (IsOwned)
        {
            <span class="book-card-owned-badge @(IsPremiumOwned ? "is-premium" : "")">
                <Icon Name="@(IsPremiumOwned ? "star" : "check")" Size="12" />
                @(IsPremiumOwned ? "Premium" : "Owned")
            </span>
        }
        @if (ShowFavoriteToggle)
        {
            <button class="book-card-favorite @(IsFavorite ? "is-favorite" : "")"
                    @onclick="() => OnFavoriteToggle.InvokeAsync(!IsFavorite)" @onclick:stopPropagation="true"
                    title="@(IsFavorite ? "Remove from favorites" : "Add to favorites")" aria-label="Toggle favorite">
                <Icon Name="@(IsFavorite ? "heart-filled" : "heart")" Size="16" />
            </button>
        }
    </div>
    <div class="book-card-body">
        <div class="book-card-title">@Title</div>
        @if (!string.IsNullOrWhiteSpace(MetaText))
        {
            <div class="book-card-meta">@MetaText</div>
        }
        @if (ShowFooter)
        {
            <div class="book-card-footer">
                @if (ShowPrice)
                {
                    <span class="book-card-price">
                        ₱@Price.ToString("N2")
                        @if (PremiumPrice is decimal premium)
                        {
                            <span class="book-card-price-premium">★ ₱@premium.ToString("N2")</span>
                        }
                    </span>
                }
                else if (IsPremiumOwned)
                {
                    <span class="badge badge-premium">★ Premium</span>
                }
                else
                {
                    <span class="badge">Owned</span>
                }
                <div class="book-card-actions">
                    @if (ShowAddToCartButton)
                    {
                        <button class="btn btn-ghost btn-icon @(IsInCart ? "is-in-cart" : "")" disabled="@IsInCart"
                                @onclick="() => OnAddToCart.InvokeAsync()" @onclick:stopPropagation="true"
                                title="@(IsInCart ? "In cart" : "Add to cart")" aria-label="@(IsInCart ? "In cart" : "Add to cart")">
                            <Icon Name="@(IsInCart ? "check" : "cart")" Size="16" />
                        </button>
                    }
                    @if (ShowActionButton)
                    {
                        <button class="btn btn-primary" @onclick="() => OnActionClick.InvokeAsync()" @onclick:stopPropagation="true">@ActionLabel</button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? CoverImageUrl { get; set; }
    [Parameter] public string? MetaText { get; set; }
    [Parameter] public decimal Price { get; set; }
    [Parameter] public decimal? PremiumPrice { get; set; }
    [Parameter] public bool IsOwned { get; set; }
    [Parameter] public bool IsPremiumOwned { get; set; }
    [Parameter] public bool ShowPrice { get; set; } = true;
    [Parameter] public bool ShowFooter { get; set; } = true;
    [Parameter] public string ActionLabel { get; set; } = "Buy";
    [Parameter] public bool ShowActionButton { get; set; } = true;
    [Parameter] public EventCallback OnActionClick { get; set; }
    [Parameter] public bool ShowAddToCartButton { get; set; }
    [Parameter] public bool IsInCart { get; set; }
    [Parameter] public EventCallback OnAddToCart { get; set; }
    [Parameter] public bool ShowFavoriteToggle { get; set; }
    [Parameter] public bool IsFavorite { get; set; }
    [Parameter] public EventCallback<bool> OnFavoriteToggle { get; set; }

    private string _resolvedCover = "imgs/app_logo.png";
    private bool _fallbackApplied;

    protected override void OnParametersSet()
    {
        if (!_fallbackApplied)
            _resolvedCover = string.IsNullOrWhiteSpace(CoverImageUrl) ? "imgs/app_logo.png" : CoverImageUrl!;
    }

    private void OnImageError()
    {
        _fallbackApplied = true;
        _resolvedCover = "imgs/app_logo.png";
    }
}
