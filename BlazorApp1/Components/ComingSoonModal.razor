@if (IsOpen)
{
    <div class="modal-backdrop" @onclick="Close">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="icon-badge">
                <Icon Name="clock" Size="28" />
            </div>
            <h3>Purchases opening soon</h3>
            <p class="form-hint">
                We're still setting up checkout for the web. Buying books here will be available soon &mdash;
                thanks for your patience!
            </p>
            <button class="btn btn-primary btn-block" @onclick="Close">Got it</button>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
}
