@using System.ComponentModel.DataAnnotations
@inject IAppService AppService

<h1>Tell us about you</h1>
<p class="form-hint">A few details to finish setting up your account.</p>

<EditForm Model="_model" OnValidSubmit="Submit" class="auth-form">
    <DataAnnotationsValidator />

    <div class="form-field">
        <label for="prof-first">First name</label>
        <InputText id="prof-first" autocomplete="given-name" @bind-Value="_model.FirstName" />
        <ValidationMessage For="() => _model.FirstName" />
    </div>

    <div class="form-field">
        <label for="prof-last">Last name</label>
        <InputText id="prof-last" autocomplete="family-name" @bind-Value="_model.LastName" />
        <ValidationMessage For="() => _model.LastName" />
    </div>

    <div class="form-field">
        <label for="prof-phone">Phone number</label>
        <InputText id="prof-phone" autocomplete="tel" @bind-Value="_model.PhoneNumber" />
        <ValidationMessage For="() => _model.PhoneNumber" />
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="form-error">@_error</p>
    }

    <button type="submit" class="btn btn-primary btn-block" disabled="@_busy">
        @(_busy ? "Saving..." : "Continue")
    </button>
</EditForm>

@code {
    [Parameter] public EventCallback OnProfileSaved { get; set; }

    private readonly ProfileModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task Submit()
    {
        _error = null;
        _busy = true;

        try
        {
            await AppService.CreateUser(_model.FirstName.Trim(), _model.LastName.Trim(), _model.PhoneNumber.Trim());
            await OnProfileSaved.InvokeAsync();
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "Could not save your profile. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }

    private class ProfileModel
    {
        [Required(ErrorMessage = "Please enter your first name.")]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Please enter your last name.")]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Please enter your phone number.")]
        [Phone(ErrorMessage = "Please enter a valid phone number.")]
        public string PhoneNumber { get; set; } = "";
    }
}
