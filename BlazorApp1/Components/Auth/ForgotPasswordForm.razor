@using System.ComponentModel.DataAnnotations
@inject IAppAuthentication Auth

@if (_sent)
{
    <div class="centered-notice card">
        <h2>Check your email</h2>
        <p class="form-hint">
            We've sent a password reset link to <strong>@_model.Email</strong>. Click the link, then sign in with your new password.
        </p>
        <p class="form-hint">Don't see it? Check your spam or junk folder.</p>

        <button type="button" class="btn btn-primary btn-block" @onclick="() => OnBackToLogin.InvokeAsync()">Back to Sign In</button>
    </div>
}
else
{
    <h1>Reset your password</h1>
    <p class="form-hint">Enter your email address and we'll send you a link to reset your password.</p>

    <EditForm Model="_model" OnValidSubmit="Submit" class="auth-form">
        <DataAnnotationsValidator />

        <div class="form-field">
            <label for="forgot-email">Email</label>
            <InputText id="forgot-email" type="email" autocomplete="email" @bind-Value="_model.Email" />
            <ValidationMessage For="() => _model.Email" />
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="form-error">@_error</p>
        }

        <button type="submit" class="btn btn-primary btn-block" disabled="@_busy">
            @(_busy ? "Sending..." : "Send Reset Link")
        </button>
    </EditForm>

    <p class="form-hint auth-switch">
        <button type="button" class="btn-link" @onclick="() => OnBackToLogin.InvokeAsync()">Back to Sign In</button>
    </p>
}

@code {
    [Parameter] public EventCallback OnBackToLogin { get; set; }

    private readonly ForgotPasswordModel _model = new();
    private string? _error;
    private bool _busy;
    private bool _sent;

    private async Task Submit()
    {
        _error = null;
        _busy = true;

        try
        {
            await Auth.SendPasswordResetEmailAsync(_model.Email.Trim());
            _sent = true;
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Please enter your email address.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = "";
    }
}
