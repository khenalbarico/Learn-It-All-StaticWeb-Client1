@using System.ComponentModel.DataAnnotations
@inject AuthSessionState AuthState
@inject IAppAuthentication Auth
@inject NavigationManager Nav

<h1>Welcome back</h1>
<p class="form-hint">Sign in to browse and read your books.</p>

<EditForm Model="_model" OnValidSubmit="Submit" class="auth-form">
    <DataAnnotationsValidator />

    <div class="form-field">
        <label for="login-email">Email</label>
        <InputText id="login-email" type="email" autocomplete="email" @bind-Value="_model.Email" />
        <ValidationMessage For="() => _model.Email" />
    </div>

    <div class="form-field">
        <label for="login-password">Password</label>
        <InputText id="login-password" type="password" autocomplete="current-password" @bind-Value="_model.Password" />
        <ValidationMessage For="() => _model.Password" />
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="form-error">@_error</p>
    }

    @if (_showResend)
    {
        <p class="form-hint">
            <button type="button" class="btn btn-ghost" @onclick="Resend" disabled="@_busy">Resend verification email</button>
        </p>
    }

    <button type="submit" class="btn btn-primary btn-block" disabled="@_busy">
        @(_busy ? "Signing in..." : "Sign In")
    </button>
</EditForm>

<p class="form-hint auth-switch">
    Don't have an account?
    <button type="button" class="btn-link" @onclick="() => OnRegisterClick.InvokeAsync()">Create one</button>
</p>

@code {
    [Parameter] public EventCallback OnRegisterClick { get; set; }

    private readonly LoginModel _model = new();
    private string? _error;
    private bool _showResend;
    private bool _busy;

    private async Task Submit()
    {
        _error = null;
        _showResend = false;
        _busy = true;

        try
        {
            await AuthState.SignInAsync(_model.Email.Trim(), _model.Password);
            Nav.NavigateTo("/");
        }
        catch (EmailNotVerifiedException)
        {
            _error = "Please verify your email address before signing in.";
            _showResend = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Resend()
    {
        _busy = true;
        try
        {
            await Auth.SendEmailVerificationAsync();
            _error = "Verification email sent. Please check your inbox.";
            _showResend = false;
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "Could not resend the verification email. Please try signing in again.";
        }
        finally
        {
            _busy = false;
        }
    }

    private class LoginModel
    {
        [Required(ErrorMessage = "Please enter your email address.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Please enter your password.")]
        public string Password { get; set; } = "";
    }
}
