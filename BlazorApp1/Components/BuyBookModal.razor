@implements IDisposable
@inject IPaymentService PaymentService
@inject LibraryCacheService LibraryCache

@if (IsOpen)
{
    <div class="modal-backdrop" @onclick="CloseIfAllowed">
        <div class="modal-box qr-modal" @onclick:stopPropagation="true">
            @if (_stage == Stage.Details)
            {
                @if (Items.Count == 1)
                {
                    <img class="book-detail-cover" src="@ResolveCover(Items[0].CoverUrl)" alt="@Items[0].Title cover" />
                    <h3>@Items[0].Title</h3>
                    @if (!string.IsNullOrWhiteSpace(Items[0].Description))
                    {
                        <p class="form-hint book-detail-desc">@Items[0].Description</p>
                    }
                    <div class="book-detail-price">₱@Items[0].Price.ToString("N2")</div>
                }
                else
                {
                    <h3>Checkout (@Items.Count books)</h3>
                    <div class="checkout-items">
                        @foreach (var item in Items)
                        {
                            <div class="checkout-item">
                                <img class="checkout-item-cover" src="@ResolveCover(item.CoverUrl)" alt="@item.Title cover" />
                                <span class="checkout-item-title">@item.Title</span>
                                <span class="checkout-item-price">₱@item.Price.ToString("N2")</span>
                            </div>
                        }
                    </div>
                    <div class="checkout-total">
                        <span>Total</span>
                        <strong>₱@TotalPrice.ToString("N2")</strong>
                    </div>
                }
                <button class="btn btn-primary btn-block" @onclick="StartAsync" disabled="@(_guard.IsBusy || Items.Count == 0)">Confirm Purchase</button>
                <button class="btn btn-ghost btn-block" @onclick="Close">Cancel</button>
            }
            else
            {
                <h3>@HeaderText</h3>

                @if (_stage == Stage.Loading)
                {
                    <div class="spinner"></div>
                    <p class="form-hint">Generating your QR code...</p>
                }
                else if (_stage == Stage.Verifying)
                {
                    <div class="spinner"></div>
                    <p class="form-hint">Confirming your payment...</p>
                }
                else if (_stage == Stage.Error)
                {
                    <ErrorBanner Message="@_error" />
                    <button class="btn btn-ghost btn-block" @onclick="Close">Close</button>
                }
                else if (_stage == Stage.AwaitingPayment)
                {
                    <p class="form-hint">Scan with any QR Ph-enabled banking or e-wallet app.</p>
                    <img class="qr-image" src="@_qrImageUrl" alt="QR Ph payment code" />
                    <div class="book-detail-price">₱@_amount.ToString("N2")</div>
                    <div class="qr-countdown">@FormatRemaining()</div>
                    <p class="form-hint">Waiting for payment confirmation...</p>
                    <button class="btn btn-ghost btn-block" @onclick="Close">Cancel</button>
                }
                else if (_stage == Stage.Succeeded)
                {
                    <div class="icon-badge"><Icon Name="check" Size="28" /></div>
                    <h3>Payment successful!</h3>
                    <p class="form-hint">@SuccessMessage</p>
                    <button class="btn btn-primary btn-block" @onclick="Close">Done</button>
                }
                else if (_stage == Stage.Expired)
                {
                    <div class="icon-badge icon-badge-danger"><Icon Name="clock" Size="28" /></div>
                    <h3>QR code expired</h3>
                    <p class="form-hint">This code was only valid for 2 minutes. You can generate a new one.</p>
                    @if (_cooldownSeconds > 0)
                    {
                        <button class="btn btn-primary btn-block" disabled>Try again in @(_cooldownSeconds)s</button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-block" @onclick="StartAsync" disabled="@_guard.IsBusy">Try Again</button>
                    }
                }
                else if (_stage == Stage.Failed)
                {
                    <div class="icon-badge icon-badge-danger"><Icon Name="alert" Size="28" /></div>
                    <h3>Payment failed</h3>
                    <p class="form-hint">@(_error ?? "The payment could not be completed.")</p>
                    @if (_cooldownSeconds > 0)
                    {
                        <button class="btn btn-primary btn-block" disabled>Try again in @(_cooldownSeconds)s</button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-block" @onclick="StartAsync" disabled="@_guard.IsBusy">Try Again</button>
                    }
                }
            }
        </div>
    </div>
}

@code {
    private enum Stage { Details, Loading, AwaitingPayment, Verifying, Succeeded, Failed, Expired, Error }

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public List<CheckoutItem> Items { get; set; } = [];
    [Parameter] public EventCallback OnPurchased { get; set; }

    private Stage _stage = Stage.Details;
    private string? _qrImageUrl;
    private string? _paymentIntentId;
    private string? _startedForKey;
    private DateTime _expiresAtUtc;
    private decimal _amount;
    private string? _error;
    private int _cooldownSeconds;
    private CancellationTokenSource? _cts;
    private readonly SubmitGuard _guard = new();

    private decimal TotalPrice => Items.Sum(i => i.Price);

    private string HeaderText => Items.Count == 1 ? Items[0].Title : $"{Items.Count} books";

    private string SuccessMessage => Items.Count == 1
        ? $"{Items[0].Title} has been added to your library."
        : $"{Items.Count} books have been added to your library.";

    private static string ResolveCover(string? url) => string.IsNullOrWhiteSpace(url) ? "imgs/app_logo.png" : url!;

    private string ItemsKey => string.Join(",", Items.Select(i => i.BookUid));

    protected override void OnParametersSet()
    {
        if (IsOpen && _startedForKey != ItemsKey)
        {
            _startedForKey = ItemsKey;
            _stage = Stage.Details;
            _error = null;
        }
    }

    private Task StartAsync() => _guard.RunAsync(async () =>
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        _stage = Stage.Loading;
        _error = null;
        StateHasChanged();

        try
        {
            var result = await PaymentService.CreatePaymentIntent(Items.Select(i => i.BookUid).ToList());
            _paymentIntentId = result.PaymentIntentId;
            _qrImageUrl = result.QrImageUrl;
            _expiresAtUtc = result.ExpiresAt;
            _amount = result.Amount;
            _stage = Stage.AwaitingPayment;

            _ = PollAsync(_cts.Token);
            _ = TickAsync(_cts.Token);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            _error = "You already own this book.";
            _stage = Stage.Error;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
        {
            _error = "Too many attempts. Please wait a bit before trying again.";
            _stage = Stage.Error;
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
            _stage = Stage.Error;
        }
        catch (Exception)
        {
            _error = "Could not start the payment. Please try again.";
            _stage = Stage.Error;
        }

        StateHasChanged();
    });

    private async Task PollAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && _stage == Stage.AwaitingPayment)
            {
                await Task.Delay(TimeSpan.FromSeconds(4), token);
                if (token.IsCancellationRequested) return;
                if (_stage != Stage.AwaitingPayment) return;

                try
                {
                    var status = await PaymentService.GetPaymentStatus(_paymentIntentId!, forceVerify: false);
                    ApplyStatus(status);
                }
                catch (Exception)
                {
                }

                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task TickAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && _stage == Stage.AwaitingPayment)
            {
                if (DateTime.UtcNow >= _expiresAtUtc)
                {
                    await FinalizeExpiryAsync(token);
                    return;
                }

                await Task.Delay(TimeSpan.FromSeconds(1), token);
                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    // Local clock hitting zero doesn't mean the payment truly missed the window: the bank/QR
    // Ph rail may have completed the transfer a moment before expiry, with confirmation still
    // in flight. Do one authoritative check against PayMongo, then give the server's webhook a
    // short cheap grace window to land before telling the user the payment was lost.
    private async Task FinalizeExpiryAsync(CancellationToken token)
    {
        _stage = Stage.Verifying;
        StateHasChanged();

        try
        {
            var status = await PaymentService.GetPaymentStatus(_paymentIntentId!, forceVerify: true);
            ApplyStatus(status);
        }
        catch (Exception)
        {
            _stage = Stage.Expired;
            StartCooldown();
        }

        if (_stage == Stage.Expired)
        {
            await GracePollAsync(token);
        }

        StateHasChanged();
    }

    private async Task GracePollAsync(CancellationToken token)
    {
        var deadline = DateTime.UtcNow.AddSeconds(24);

        try
        {
            while (!token.IsCancellationRequested && _stage == Stage.Expired && DateTime.UtcNow < deadline)
            {
                await Task.Delay(TimeSpan.FromSeconds(4), token);
                if (token.IsCancellationRequested || _stage != Stage.Expired) return;

                try
                {
                    var status = await PaymentService.GetPaymentStatus(_paymentIntentId!, forceVerify: false);
                    ApplyStatus(status);
                }
                catch (Exception)
                {
                }

                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ApplyStatus(PaymentStatusResult status)
    {
        var previousStage = _stage;

        _stage = status.Status switch
        {
            "Succeeded" => Stage.Succeeded,
            "Failed" => Stage.Failed,
            "Expired" => Stage.Expired,
            _ => previousStage == Stage.Verifying ? Stage.Expired : previousStage
        };

        if (_stage == Stage.Succeeded && previousStage != Stage.Succeeded)
        {
            LibraryCache.InvalidateMyLibrary();
            _ = OnPurchased.InvokeAsync();
        }

        if (_stage is Stage.Expired or Stage.Failed && previousStage != _stage)
        {
            StartCooldown();
        }
    }

    private void StartCooldown()
    {
        _cooldownSeconds = 30;
        _ = CooldownTickAsync();
    }

    private async Task CooldownTickAsync()
    {
        while (_cooldownSeconds > 0)
        {
            await Task.Delay(1000);
            _cooldownSeconds--;
            StateHasChanged();
        }
    }

    private string FormatRemaining()
    {
        var remaining = _expiresAtUtc - DateTime.UtcNow;
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;
        return $"{(int)remaining.TotalMinutes}:{remaining.Seconds:D2}";
    }

    private async Task CloseIfAllowed()
    {
        if (_stage is Stage.AwaitingPayment or Stage.Loading or Stage.Verifying) return;
        await Close();
    }

    private async Task Close()
    {
        _cts?.Cancel();
        _paymentIntentId = null;
        _startedForKey = null;
        _stage = Stage.Details;
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    public void Dispose()
    {
        _cts?.Cancel();
    }
}
