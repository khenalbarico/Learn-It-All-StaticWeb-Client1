@page "/account"
@implements IDisposable
@using System.ComponentModel.DataAnnotations
@using BlazorApp1.Models.Validation
@inject AuthSessionState AuthState
@inject IAppService AppService
@inject IAppAuthentication Auth

<PageTitle>Account - Learn It All</PageTitle>

<div class="page-container">
    <h1>Account</h1>

    <AuthGate GuestMessage="Log in to manage your account.">
        @if (AuthState.CurrentUser is null && AuthState.ProfileLoadError is not null)
        {
            <ErrorBanner Message="@AuthState.ProfileLoadError" OnRetry="() => AuthState.RefreshProfileAsync()" />
        }
        else if (AuthState.CurrentUser is null)
        {
            <div class="spinner"></div>
        }
        else
        {
            <div class="card">
                <div class="section-header">
                    <h2>Profile</h2>
                    @if (IsProfileDirty)
                    {
                        <span class="unsaved-badge"><span class="dot"></span> Unsaved changes</span>
                    }
                </div>

                <div class="form-field">
                    <label>Email</label>
                    <input value="@AuthState.CurrentUser.Email" disabled />
                </div>

                <EditForm Model="_profileModel" OnValidSubmit="SaveProfile">
                    <DataAnnotationsValidator />

                    <div class="form-field">
                        <label for="acc-first">First name</label>
                        <InputText id="acc-first" autocomplete="given-name"
                                   @bind-Value="_profileModel.FirstName" @bind-Value:event="oninput" />
                        <ValidationMessage For="() => _profileModel.FirstName" />
                    </div>

                    <div class="form-field">
                        <label for="acc-last">Last name</label>
                        <InputText id="acc-last" autocomplete="family-name"
                                   @bind-Value="_profileModel.LastName" @bind-Value:event="oninput" />
                        <ValidationMessage For="() => _profileModel.LastName" />
                    </div>

                    <div class="form-field">
                        <label for="acc-phone">Phone number</label>
                        <InputText id="acc-phone" autocomplete="tel"
                                   @bind-Value="_profileModel.PhoneNumber" @bind-Value:event="oninput" />
                        <ValidationMessage For="() => _profileModel.PhoneNumber" />
                    </div>

                    @if (!string.IsNullOrEmpty(_profileMessage))
                    {
                        <p class="@(_profileSuccess ? "form-hint" : "form-error")">@_profileMessage</p>
                    }

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" disabled="@(_profileBusy || !IsProfileDirty)">
                            @(_profileBusy ? "Saving..." : "Save Changes")
                        </button>
                        @if (IsProfileDirty)
                        {
                            <button type="button" class="btn btn-ghost" @onclick="ResetProfile" disabled="@_profileBusy">
                                Discard
                            </button>
                        }
                    </div>
                </EditForm>
            </div>

            <details class="card password-section">
                <summary>Change Password</summary>

                <EditForm Model="_passwordModel" OnValidSubmit="ChangePassword">
                    <DataAnnotationsValidator />

                    <div class="form-field">
                        <label for="acc-newpass">New password</label>
                        <InputText id="acc-newpass" type="password" autocomplete="new-password"
                                   @bind-Value="_passwordModel.NewPassword" @bind-Value:event="oninput" />
                        <ValidationMessage For="() => _passwordModel.NewPassword" />
                    </div>

                    <PasswordStrengthHint Password="@_passwordModel.NewPassword" />

                    <div class="form-field">
                        <label for="acc-confirmpass">Confirm new password</label>
                        <InputText id="acc-confirmpass" type="password" autocomplete="new-password"
                                   @bind-Value="_passwordModel.ConfirmPassword" />
                        <ValidationMessage For="() => _passwordModel.ConfirmPassword" />
                    </div>

                    @if (!string.IsNullOrEmpty(_passwordMessage))
                    {
                        <p class="@(_passwordSuccess ? "form-hint" : "form-error")">@_passwordMessage</p>
                    }

                    <button type="submit" class="btn btn-secondary" disabled="@_passwordBusy">
                        @(_passwordBusy ? "Updating..." : "Update Password")
                    </button>
                </EditForm>
            </details>
        }
    </AuthGate>
</div>

@code {
    private readonly ProfileModel _profileModel = new();
    private readonly PasswordModel _passwordModel = new();

    private string _originalFirstName = "";
    private string _originalLastName = "";
    private string _originalPhoneNumber = "";
    private bool _initialSyncDone;

    private bool _profileBusy;
    private string? _profileMessage;
    private bool _profileSuccess;

    private bool _passwordBusy;
    private string? _passwordMessage;
    private bool _passwordSuccess;

    private bool IsProfileDirty =>
        _profileModel.FirstName.Trim() != _originalFirstName ||
        _profileModel.LastName.Trim() != _originalLastName ||
        _profileModel.PhoneNumber.Trim() != _originalPhoneNumber;

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthChanged;
        SyncModelFromUser();
    }

    private void OnAuthChanged()
    {
        SyncModelFromUser();
        StateHasChanged();
    }

    private void SyncModelFromUser()
    {
        if (_initialSyncDone || AuthState.CurrentUser is null) return;

        ApplySnapshot(
            AuthState.CurrentUser.FirstName ?? "",
            AuthState.CurrentUser.LastName ?? "",
            AuthState.CurrentUser.PhoneNumber ?? "");
        _initialSyncDone = true;
    }

    private void ApplySnapshot(string firstName, string lastName, string phoneNumber)
    {
        _profileModel.FirstName = firstName;
        _profileModel.LastName = lastName;
        _profileModel.PhoneNumber = phoneNumber;
        _originalFirstName = firstName;
        _originalLastName = lastName;
        _originalPhoneNumber = phoneNumber;
    }

    private void ResetProfile()
    {
        _profileMessage = null;
        ApplySnapshot(_originalFirstName, _originalLastName, _originalPhoneNumber);
    }

    private async Task SaveProfile()
    {
        _profileMessage = null;
        _profileBusy = true;

        var firstName = _profileModel.FirstName.Trim();
        var lastName = _profileModel.LastName.Trim();
        var phoneNumber = _profileModel.PhoneNumber.Trim();

        try
        {
            await AppService.CreateUser(firstName, lastName, phoneNumber);
            ApplySnapshot(firstName, lastName, phoneNumber);
            _profileMessage = "Profile updated.";
            _profileSuccess = true;
            _ = AuthState.RefreshProfileAsync();
        }
        catch (ApiUnavailableException ex)
        {
            _profileMessage = ex.Message;
            _profileSuccess = false;
        }
        catch (Exception)
        {
            _profileMessage = "Could not save your changes. Please try again.";
            _profileSuccess = false;
        }
        finally
        {
            _profileBusy = false;
        }
    }

    private async Task ChangePassword()
    {
        _passwordMessage = null;
        _passwordBusy = true;

        try
        {
            if (await Auth.IsSamePasswordAsync(AuthState.CurrentUser?.Email ?? "", _passwordModel.NewPassword))
            {
                _passwordMessage = "New password must be different from your current password.";
                _passwordSuccess = false;
                return;
            }

            await Auth.ChangePasswordAsync(_passwordModel.NewPassword);
            _passwordMessage = "Password updated.";
            _passwordSuccess = true;
            _passwordModel.NewPassword = "";
            _passwordModel.ConfirmPassword = "";
        }
        catch (ApiUnavailableException ex)
        {
            _passwordMessage = ex.Message;
            _passwordSuccess = false;
        }
        catch (Exception)
        {
            _passwordMessage = "Could not update your password. Please try again.";
            _passwordSuccess = false;
        }
        finally
        {
            _passwordBusy = false;
        }
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthChanged;
    }

    private class ProfileModel
    {
        [Required(ErrorMessage = "Please enter your first name.")]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Please enter your last name.")]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Please enter your phone number.")]
        [Phone(ErrorMessage = "Please enter a valid phone number.")]
        public string PhoneNumber { get; set; } = "";
    }

    private class PasswordModel
    {
        [Required(ErrorMessage = "Please enter a new password.")]
        [StrongPassword]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your new password.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
