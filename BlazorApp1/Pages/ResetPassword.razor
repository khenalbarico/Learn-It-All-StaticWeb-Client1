@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@using BlazorApp1.Models.Validation
@inject IAppAuthentication Auth
@inject NavigationManager Nav

<PageTitle>Reset Password - Learn It All</PageTitle>

<div class="form-container">
    @if (_verifying)
    {
        <div class="centered-notice card">
            <div class="spinner"></div>
        </div>
    }
    else if (_invalidCode)
    {
        <div class="centered-notice card">
            <h2>Link expired or invalid</h2>
            <p class="form-hint">This password reset link is no longer valid. Please request a new one.</p>
            <button class="btn btn-primary btn-block" @onclick="GoToAuth">Request New Link</button>
        </div>
    }
    else if (_done)
    {
        <div class="centered-notice card">
            <h2>Password updated</h2>
            <p class="form-hint">Your password has been reset. You can now sign in with your new password.</p>
            <button class="btn btn-primary btn-block" @onclick="GoToAuth">Sign In</button>
        </div>
    }
    else
    {
        <h1>Set a new password</h1>
        <p class="form-hint">Choose a new password for <strong>@_email</strong>.</p>

        <EditForm Model="_model" OnValidSubmit="Submit" class="auth-form">
            <DataAnnotationsValidator />

            <div class="form-field">
                <label for="reset-newpass">New password</label>
                <InputText id="reset-newpass" type="password" autocomplete="new-password"
                           @bind-Value="_model.NewPassword" />
                <ValidationMessage For="() => _model.NewPassword" />
            </div>

            <PasswordStrengthHint Password="@_model.NewPassword" />

            <div class="form-field">
                <label for="reset-confirmpass">Confirm new password</label>
                <InputText id="reset-confirmpass" type="password" autocomplete="new-password" @bind-Value="_model.ConfirmPassword" />
                <ValidationMessage For="() => _model.ConfirmPassword" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="form-error">@_error</p>
            }

            <button type="submit" class="btn btn-primary btn-block" disabled="@_busy">
                @(_busy ? "Updating..." : "Reset Password")
            </button>
        </EditForm>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "oobCode")] public string? OobCode { get; set; }

    private readonly ResetPasswordModel _model = new();
    private string? _error;
    private string _email = "";
    private bool _busy;
    private bool _verifying = true;
    private bool _invalidCode;
    private bool _done;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(OobCode))
        {
            _invalidCode = true;
            _verifying = false;
            return;
        }

        try
        {
            _email = await Auth.VerifyPasswordResetCodeAsync(OobCode);
        }
        catch (Exception)
        {
            _invalidCode = true;
        }
        finally
        {
            _verifying = false;
        }
    }

    private async Task Submit()
    {
        _error = null;
        _busy = true;

        try
        {
            if (await Auth.IsSamePasswordAsync(_email, _model.NewPassword))
            {
                _error = "New password must be different from your previous password.";
                return;
            }

            await Auth.ResetPasswordAsync(OobCode!, _model.NewPassword);
            _done = true;
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoToAuth() => Nav.NavigateTo("/auth");

    private class ResetPasswordModel
    {
        [Required(ErrorMessage = "Please enter a new password.")]
        [StrongPassword]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your new password.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
