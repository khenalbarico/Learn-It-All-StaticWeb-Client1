@page "/library"
@implements IDisposable
@inject AuthSessionState AuthState
@inject IAppService AppService
@inject LibraryCacheService LibraryCache
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Library - Learn It All</PageTitle>

<div class="page-container">
    <h1>Library</h1>

    @if (!AuthState.IsAuthenticated && !AuthState.IsInitializing)
    {
        <p class="banner">You're browsing as a guest. Sample books are shown below &mdash; authenticate to see the real catalog.</p>
    }

    <CategoryTabs Categories="_categories" SelectedCategory="@_selectedCategory" SelectedCategoryChanged="OnCategoryChanged" IsBusy="_loading" />

    <div class="search-field">
        <Icon Name="search" Size="18" />
        <input type="search" placeholder="Search books..." value="@_searchTerm" @oninput="OnSearchInput" />
    </div>

    @if (AuthState.IsAuthenticated && AuthState.ProfileLoadError is not null)
    {
        <ErrorBanner Message="@AuthState.ProfileLoadError" OnRetry="() => AuthState.RefreshProfileAsync()" />
    }
    else if (AuthState.IsInitializing || (AuthState.IsAuthenticated && AuthState.CurrentUser is null) || _loading)
    {
        <div class="book-grid">
            @for (var i = 0; i < 8; i++)
            {
                <BookCardSkeleton />
            }
        </div>
    }
    else if (_error is not null)
    {
        <ErrorBanner Message="@_error" OnRetry="() => LoadCategoryAsync(_selectedCategory)" />
    }
    else if (_books.Count == 0)
    {
        <EmptyState Message="@(string.IsNullOrWhiteSpace(_searchTerm) ? "No books in this category yet." : $"No books match \"{_searchTerm}\".")" />
    }
    else
    {
        <div class="book-grid">
            @for (var i = 0; i < _books.Count; i++)
            {
                var book = _books[i];
                <div style="--card-index: @i">
                    <BookCard Title="@book.Title"
                              CoverImageUrl="@book.CoverImageUrl"
                              Price="@book.Price"
                              ShowPrice="@(!IsOwned(book.Uid))"
                              ActionLabel="@(IsOwned(book.Uid) ? "Owned" : "Buy")"
                              ShowActionButton="@(!IsOwned(book.Uid))"
                              OnActionClick="() => OnBuyClick(book)"
                              ShowAddToCartButton="@(AuthState.IsAuthenticated && !IsOwned(book.Uid))"
                              IsInCart="@IsInCart(book.Uid)"
                              OnAddToCart="() => OnAddToCart(book)" />
                </div>
            }
        </div>
    }
</div>

<AuthRequiredModal @bind-IsOpen="_authRequiredOpen" />

<BuyBookModal @bind-IsOpen="_paymentModalOpen"
              Items="_checkoutItems"
              OnPurchased="OnBookPurchased" />

@code {
    private readonly List<(string Value, string Label)> _categories =
    [
        ("CollegeCourse", "College Course"),
        ("Reviewer", "Reviewer")
    ];

    [SupplyParameterFromQuery(Name = "category")]
    [Parameter]
    public string? CategoryQuery { get; set; }

    private string _selectedCategory = "CollegeCourse";
    private List<BookCardData> _categoryBooks = [];
    private string _searchTerm = "";
    private bool _loading;
    private string? _error;
    private bool _authRequiredOpen;
    private bool _paymentModalOpen;
    private List<CheckoutItem> _checkoutItems = [];
    private List<DummyBook>? _dummyCatalog;

    private List<BookCardData> _books => string.IsNullOrWhiteSpace(_searchTerm)
        ? _categoryBooks
        : _categoryBooks.Where(b => b.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthChanged;

        if (!string.IsNullOrWhiteSpace(CategoryQuery))
        {
            var match = _categories.FirstOrDefault(c => string.Equals(c.Value, CategoryQuery, StringComparison.OrdinalIgnoreCase));
            if (match != default)
                _selectedCategory = match.Value;
        }
    }

    private void OnSearchInput(ChangeEventArgs e) => _searchTerm = e.Value?.ToString() ?? "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadCategoryAsync(_selectedCategory);
    }

    private async void OnAuthChanged()
    {
        await LoadCategoryAsync(_selectedCategory);
        StateHasChanged();
    }

    private async Task OnCategoryChanged(string category)
    {
        _selectedCategory = category;
        await LoadCategoryAsync(category);
    }

    private async Task LoadCategoryAsync(string category)
    {
        if (AuthState.IsInitializing) return;
        if (AuthState.IsAuthenticated && AuthState.CurrentUser is null) return;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            List<BookCardData> books;
            if (AuthState.IsAuthenticated)
            {
                if (LibraryCache.TryGetCategory(category, out var cached))
                {
                    books = cached.Select(ToCardData).ToList();
                }
                else
                {
                    var fetched = await AppService.GetBooksByCategory(category);
                    LibraryCache.SetCategory(category, fetched);
                    books = fetched.Select(ToCardData).ToList();
                }
            }
            else
            {
                _dummyCatalog ??= await Http.GetFromJsonAsync<List<DummyBook>>("data/dummy-books.json") ?? [];
                books = _dummyCatalog
                    .Where(b => string.Equals(b.Category, category, StringComparison.OrdinalIgnoreCase))
                    .Select(ToCardData)
                    .ToList();
            }

            _categoryBooks = books.OrderBy(b => b.Title, StringComparer.OrdinalIgnoreCase).ToList();
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
            _categoryBooks = [];
        }
        catch (Exception)
        {
            _error = "Could not load books for this category. Please try again.";
            _categoryBooks = [];
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnBuyClick(BookCardData book)
    {
        if (IsOwned(book.Uid))
        {
            Nav.NavigateTo("/my-library");
            return;
        }

        if (AuthState.IsAuthenticated && !string.IsNullOrEmpty(book.Uid))
        {
            _checkoutItems = [new CheckoutItem(book.Uid, book.Title, book.CoverImageUrl, book.Price, book.Description)];
            _paymentModalOpen = true;
        }
        else
        {
            _authRequiredOpen = true;
        }
    }

    private bool IsOwned(string bookUid)
        => !string.IsNullOrEmpty(bookUid) && AuthState.CurrentUser?.Library.Any(l => l.Uid == bookUid) == true;

    private bool IsInCart(string bookUid)
        => !string.IsNullOrEmpty(bookUid) && AuthState.CurrentUser?.Cart.Any(c => c.BookUid == bookUid) == true;

    private async Task OnAddToCart(BookCardData book)
    {
        if (string.IsNullOrEmpty(book.Uid) || IsOwned(book.Uid) || IsInCart(book.Uid)) return;
        AuthState.AddToCartLocal(book.Uid);
        await AppService.AddToCart(book.Uid);
    }

    private async Task OnBookPurchased() => await AuthState.RefreshProfileAsync();

    private static BookCardData ToCardData(Book book) => new(book.Uid, book.Title ?? "Untitled", book.ImageCoverUrl, book.Price, book.Description);

    private static BookCardData ToCardData(DummyBook book) => new("", book.Title, book.CoverImage, book.Price, book.Description);

    private record BookCardData(string Uid, string Title, string? CoverImageUrl, decimal Price, string? Description);

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthChanged;
    }
}
