@page "/auth"
@implements IDisposable
@inject AuthSessionState AuthState
@inject NavigationManager Nav

<PageTitle>Sign In - Learn It All</PageTitle>

<div class="auth-callback-page">
    @if (AuthState.IsBusy)
    {
        <div class="auth-loading">
            <div class="spinner"></div>
            <p class="form-hint">Finishing sign-in...</p>
        </div>
    }
    else if (!AuthState.IsAuthenticated)
    {
        <h1>Welcome</h1>
        <p class="form-hint">Sign in or create your account with Google, Facebook, or Microsoft on the next screen.</p>

        <button type="button" class="btn btn-primary btn-block" @onclick="SignIn">
            Sign In / Create Account
        </button>
    }
    else if (AuthState.ProfileLoadError is not null)
    {
        <p class="form-error">@AuthState.ProfileLoadError</p>
        <button type="button" class="btn btn-secondary" @onclick="RetryProfile">Try Again</button>
    }
    else
    {
        <div class="auth-loading">
            <div class="spinner"></div>
            <p class="form-hint">Setting up your account...</p>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthChanged;
        RedirectHomeIfSignedIn();
    }

    private void OnAuthChanged()
    {
        RedirectHomeIfSignedIn();
        StateHasChanged();
    }

    private void RedirectHomeIfSignedIn()
    {
        if (!AuthState.IsBusy && AuthState.IsAuthenticated && AuthState.ProfileLoadError is null)
            Nav.NavigateTo("/");
    }

    private void SignIn() => AuthState.BeginSignIn();

    private Task RetryProfile() => AuthState.RefreshProfileAsync();

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthChanged;
    }
}
