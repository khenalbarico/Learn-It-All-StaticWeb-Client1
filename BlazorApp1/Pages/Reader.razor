@page "/read/{BookUid}/{DocUid}"
@implements IDisposable
@inject AuthSessionState AuthState
@inject IAppService AppService
@inject LibraryCacheService LibraryCache
@inject JsInteropService JsInterop
@inject NavigationManager Nav
@inject IAdSenseCfg AdCfg

<PageTitle>@(_currentDoc?.Title ?? _book?.Title ?? "Reading") - Learn It All</PageTitle>

<div class="reader-page">
    <AuthGate GuestMessage="Log in to read your books.">
        <div class="reader-toolbar">
            <button class="btn btn-ghost reader-back" @onclick="BackToLibrary" title="Back to My Library" aria-label="Back to My Library">
                <Icon Name="close" Size="18" />
            </button>

            <div class="reader-titles">
                <span class="reader-book-title">@(_book?.Title ?? "")</span>
                <span class="reader-doc-title">@(_currentDoc?.Title ?? "")</span>
            </div>

            @if (_libraryEntry is not null)
            {
                <button class="btn btn-ghost reader-favorite @(_isFavorite ? "is-favorite" : "")"
                        @onclick="ToggleFavorite" title="@(_isFavorite ? "Remove from favorites" : "Add to favorites")"
                        aria-label="Toggle favorite">
                    <Icon Name="@(_isFavorite ? "heart-filled" : "heart")" Size="18" />
                </button>
            }

            @if (_book is not null && _book.Documents.Count > 1)
            {
                <button class="btn reader-select reader-doc-switch" @onclick="() => _docListOpen = true" disabled="@_loading" aria-label="Switch document">
                    <span class="reader-doc-switch-title">@(string.IsNullOrWhiteSpace(_currentDoc?.Title) ? "Document" : _currentDoc.Title)</span>
                    @if (_currentDoc?.IsPremium == true)
                    {
                        <span class="badge badge-premium reader-doc-switch-badge">★</span>
                    }
                    <Icon Name="chevron-down" Size="14" />
                </button>
            }

            @if (_libraryBooks.Count > 1)
            {
                <select class="reader-select" value="@BookUid" @onchange="OnBookChanged" disabled="@_loading">
                    @foreach (var b in _libraryBooks)
                    {
                        <option value="@b.Uid">@(b.Title ?? "Untitled")</option>
                    }
                </select>
            }

        </div>

        <AdUnit SlotId="@AdCfg.ReaderSlotId" CssClass="ad-reader-strip" />

        @if (_loading)
        {
            <div class="reader-status">
                <div class="spinner"></div>
                <p class="form-hint">Loading document...</p>
            </div>
        }
        else if (_error is not null)
        {
            <div class="reader-status">
                <ErrorBanner Message="@_error" OnRetry="LoadDocumentAsync" />
            </div>
        }
        <div class="reader-frame" id="@_containerId" style="@(_loading || _error is not null ? "display:none" : null)"></div>

        @if (!_loading && _error is null && _totalPages > 0)
        {
            <div class="reader-controls">
                <button class="btn btn-ghost reader-pagenav-btn" @onclick="PrevPage" disabled="@(_currentPage <= 1)" aria-label="Previous page">
                    <Icon Name="chevron-left" Size="18" />
                </button>

                <form class="reader-controls-page" @onsubmit="CommitPageInput" @onsubmit:preventDefault="true">
                    <input type="number" class="reader-pagejump-input" min="1" max="@_totalPages"
                           value="@_currentPage" @onchange="OnPageInputChanged"
                           aria-label="Current page, type to jump" title="Type a page number and press Enter" />
                    <span class="reader-controls-total">/ @_totalPages</span>
                </form>

                <button class="btn btn-ghost reader-pagenav-btn" @onclick="NextPage" disabled="@(_currentPage >= _totalPages)" aria-label="Next page">
                    <Icon Name="chevron-right" Size="18" />
                </button>

                <div class="reader-controls-divider"></div>

                <button class="btn btn-ghost reader-pagenav-btn" @onclick="ZoomOut" disabled="@(_zoom <= MinZoom)" aria-label="Zoom out">
                    <Icon Name="zoom-out" Size="18" />
                </button>
                <span class="reader-controls-total reader-zoom-value">@((_zoom * 100).ToString("0"))%</span>
                <button class="btn btn-ghost reader-pagenav-btn" @onclick="ZoomIn" disabled="@(_zoom >= MaxZoom)" aria-label="Zoom in">
                    <Icon Name="zoom-in" Size="18" />
                </button>
            </div>
        }
    </AuthGate>
</div>

<DocumentListModal @bind-IsOpen="_docListOpen"
                    BookTitle="@(_book?.Title ?? "")"
                    Documents="@(_book?.Documents ?? [])"
                    OwnsPremium="@OwnsPremium"
                    HasPremiumTier="@(_book?.PremiumPrice is not null)"
                    OnDocumentSelected="OnDocumentSelectedFromModal"
                    OnUpgradeClick="OnUpgradeFromModal" />

<BuyBookModal @bind-IsOpen="_upgradeModalOpen"
              Items="_upgradeItems"
              OnPurchased="OnUpgradePurchased" />

@code {
    [Parameter] public string BookUid { get; set; } = "";
    [Parameter] public string DocUid { get; set; } = "";

    private const double MinZoom = 0.5;
    private const double MaxZoom = 4.0;
    private const int ProgressSaveDebounceMs = 1500;

    private readonly string _containerId = $"pdf-viewer-{Guid.NewGuid():N}";
    private Book? _book;
    private BookDocs? _currentDoc;
    private List<Book> _libraryBooks = [];
    private UserLibrary? _libraryEntry;
    private bool _isFavorite;
    private bool _loading = true;
    private string? _error;
    private int _currentPage = 1;
    private int _totalPages;
    private double _zoom = 1.0;
    private string? _loadedForKey;
    private CancellationTokenSource? _progressSaveCts;
    private string _pageInputValue = "";
    private bool _docListOpen;
    private bool _upgradeModalOpen;
    private List<CheckoutItem> _upgradeItems = [];

    private bool OwnsPremium => _libraryEntry?.IsPremium ?? false;

    protected override async Task OnParametersSetAsync()
    {
        if (!AuthState.IsAuthenticated) return;

        var key = $"{BookUid}/{DocUid}";
        if (_loadedForKey == key) return;
        _loadedForKey = key;

        await EnsureLibraryLoadedAsync();
        await LoadDocumentAsync();
    }

    private async Task EnsureLibraryLoadedAsync()
    {
        if (LibraryCache.TryGetMyLibrary(out var cached))
        {
            _libraryBooks = cached;
        }
        else
        {
            try
            {
                _libraryBooks = await AppService.GetMyLibraryBooks();
                LibraryCache.SetMyLibrary(_libraryBooks);
            }
            catch (Exception)
            {
                _libraryBooks = [];
            }
        }

        _book = _libraryBooks.FirstOrDefault(b => b.Uid == BookUid);
        _currentDoc = _book?.Documents.FirstOrDefault(d => d.Uid == DocUid);
        _libraryEntry = AuthState.CurrentUser?.Library.FirstOrDefault(l => l.Uid == BookUid);
        _isFavorite = _libraryEntry?.IsFavorite ?? false;
    }

    private async Task LoadDocumentAsync()
    {
        _loading = true;
        _error = null;
        _totalPages = 0;
        _currentPage = 1;
        _zoom = 1.0;
        StateHasChanged();

        try
        {
            if (!LibraryCache.TryGetDocument(BookUid, DocUid, out var bytes))
            {
                bytes = await AppService.GetBookDocumentBytes(BookUid, DocUid);
                LibraryCache.SetDocument(BookUid, DocUid, bytes);
            }

            _loading = false;
            StateHasChanged();

            _totalPages = await JsInterop.LoadPdfAsync(_containerId, bytes);
            _currentPage = 1;

            var savedProgress = _libraryEntry?.DocumentsProgress.FirstOrDefault(d => d.DocUid == DocUid);
            if (savedProgress is not null && savedProgress.Page > 1)
            {
                _currentPage = await JsInterop.GoToPdfPageAsync(_containerId, Math.Min(savedProgress.Page, _totalPages));
            }
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _error = "You do not have access to this document.";
        }
        catch (Exception)
        {
            _error = "Could not load this document. Please try again.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private Task PrevPage() => GoToPage(_currentPage - 1);

    private Task NextPage() => GoToPage(_currentPage + 1);

    private async Task GoToPage(int page)
    {
        if (_loading || _error is not null) return;
        _currentPage = await JsInterop.GoToPdfPageAsync(_containerId, page);
        ScheduleProgressSave();
        StateHasChanged();
    }

    private async Task OnPageInputChanged(ChangeEventArgs e)
    {
        _pageInputValue = e.Value?.ToString() ?? "";
        await CommitPageInput();
    }

    private async Task CommitPageInput()
    {
        if (int.TryParse(_pageInputValue, out var page) && page != _currentPage)
            await GoToPage(page);

        _pageInputValue = "";
    }

    private async Task ZoomIn()
    {
        if (_loading || _error is not null) return;
        _zoom = await JsInterop.ZoomPdfAsync(_containerId, 1);
        StateHasChanged();
    }

    private async Task ZoomOut()
    {
        if (_loading || _error is not null) return;
        _zoom = await JsInterop.ZoomPdfAsync(_containerId, -1);
        StateHasChanged();
    }

    private async void ScheduleProgressSave()
    {
        _progressSaveCts?.Cancel();
        var cts = new CancellationTokenSource();
        _progressSaveCts = cts;
        var pageToSave = _currentPage;
        var totalPagesToSave = _totalPages;

        try
        {
            await Task.Delay(ProgressSaveDebounceMs, cts.Token);
            await AppService.SaveReadingProgress(BookUid, DocUid, pageToSave, totalPagesToSave);
            AuthState.UpdateLocalReadingProgress(BookUid, DocUid, pageToSave, totalPagesToSave);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task ToggleFavorite()
    {
        var newValue = !_isFavorite;
        _isFavorite = newValue;
        StateHasChanged();

        await AppService.SetFavorite(BookUid, newValue);
        _ = AuthState.RefreshProfileAsync();
    }

    private void OnDocumentSelectedFromModal(BookDocs doc)
    {
        if (doc.Uid == DocUid) return;
        Nav.NavigateTo($"/read/{BookUid}/{doc.Uid}");
    }

    private void OnUpgradeFromModal()
    {
        if (_book is null || _book.PremiumPrice is null) return;

        _upgradeItems =
        [
            new CheckoutItem(
                _book.Uid,
                $"{_book.Title ?? "Untitled"} — Premium Upgrade",
                _book.ImageCoverUrl,
                _book.Price,
                _book.Description,
                _book.PremiumPrice,
                IsPremium: true,
                IsUpgrade: true)
        ];
        _upgradeModalOpen = true;
    }

    private async Task OnUpgradePurchased()
    {
        LibraryCache.InvalidateMyLibrary();
        await AuthState.RefreshProfileAsync();
        await EnsureLibraryLoadedAsync();
        StateHasChanged();
    }

    private void OnBookChanged(ChangeEventArgs e)
    {
        var newBookUid = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(newBookUid) || newBookUid == BookUid) return;

        var target = _libraryBooks.FirstOrDefault(b => b.Uid == newBookUid);
        var firstDoc = target?.Documents.FirstOrDefault();
        if (firstDoc is null) return;

        Nav.NavigateTo($"/read/{newBookUid}/{firstDoc.Uid}");
    }

    private void BackToLibrary() => Nav.NavigateTo("/my-library");

    public void Dispose()
    {
        _progressSaveCts?.Cancel();
        if (_totalPages > 0 && _error is null)
        {
            _ = AppService.SaveReadingProgress(BookUid, DocUid, _currentPage, _totalPages);
            AuthState.UpdateLocalReadingProgress(BookUid, DocUid, _currentPage, _totalPages);
        }

        _ = JsInterop.DisposePdfAsync(_containerId);
    }
}
