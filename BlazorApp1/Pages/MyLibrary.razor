@page "/my-library"
@implements IDisposable
@inject AuthSessionState AuthState
@inject IAppService AppService
@inject LibraryCacheService LibraryCache
@inject NavigationManager Nav

<PageTitle>My Library - Learn It All</PageTitle>

<div class="page-container">
    <h1>My Library</h1>

    <AuthGate GuestMessage="Log in to see the books you've purchased.">
        @if (_readError is not null)
        {
            <ErrorBanner Message="@_readError" OnRetry="() => { _readError = null; }" />
        }

        @if (_myLibraryBooks.Count > 0)
        {
            <div class="list-toolbar">
                <div class="search-field">
                    <Icon Name="search" Size="18" />
                    <input type="search" placeholder="Search your books..." value="@_searchTerm" @oninput="OnSearchInput" />
                </div>
                <div class="sort-field">
                    <Icon Name="sort" Size="16" />
                    <select value="@_sortMode" @onchange="OnSortChanged">
                        <option value="Alphabetical">Alphabetical</option>
                        <option value="RecentlyPurchased">Recently Purchased</option>
                        <option value="RecentlyRead">Recently Read</option>
                    </select>
                </div>
            </div>
        }

        @if (_loading)
        {
            <div class="book-grid">
                @for (var i = 0; i < 4; i++)
                {
                    <BookCardSkeleton />
                }
            </div>
        }
        else if (_error is not null)
        {
            <ErrorBanner Message="@_error" OnRetry="LoadMyLibraryAsync" />
        }
        else if (_books.Count == 0 && !string.IsNullOrWhiteSpace(_searchTerm))
        {
            <EmptyState Message="@($"No books match \"{_searchTerm}\".")" />
        }
        else if (_books.Count == 0)
        {
            <EmptyState Message="You haven't bought any books yet. Head to the Library to find something to read." />
        }
        else
        {
            <div class="book-grid">
                @for (var i = 0; i < _books.Count; i++)
                {
                    var book = _books[i];
                    <div style="--card-index: @i">
                        <BookCard Title="@(book.Title ?? "Untitled")"
                                  CoverImageUrl="@book.ImageCoverUrl"
                                  ShowPrice="false"
                                  ActionLabel="Read"
                                  OnActionClick="() => OnReadClick(book)"
                                  ShowFavoriteToggle="true"
                                  IsFavorite="@IsFavorite(book.Uid)"
                                  OnFavoriteToggle="@(isFavorite => OnFavoriteToggle(book.Uid, isFavorite))" />
                    </div>
                }
            </div>
        }
    </AuthGate>
</div>

<DocumentListModal @bind-IsOpen="_docListOpen"
                    BookTitle="@_selectedBookTitle"
                    Documents="_selectedBookDocs"
                    OnDocumentSelected="OnDocumentSelected" />

@code {
    private enum SortMode { Alphabetical, RecentlyPurchased, RecentlyRead }

    private List<Book> _myLibraryBooks = [];
    private string _searchTerm = "";
    private SortMode _sortMode = SortMode.Alphabetical;
    private bool _loading = true;
    private string? _error;
    private string? _readError;
    private bool _docListOpen;
    private string _selectedBookUid = "";
    private string _selectedBookTitle = "";
    private List<BookDocs> _selectedBookDocs = [];

    private List<Book> _books
    {
        get
        {
            var filtered = string.IsNullOrWhiteSpace(_searchTerm)
                ? _myLibraryBooks
                : _myLibraryBooks.Where(b => (b.Title ?? "").Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

            return _sortMode switch
            {
                SortMode.RecentlyPurchased => filtered.OrderByDescending(PurchasedAt).ToList(),
                SortMode.RecentlyRead => filtered
                    .OrderByDescending(b => LastReadAt(b) ?? DateTime.MinValue)
                    .ThenBy(b => b.Title, StringComparer.OrdinalIgnoreCase)
                    .ToList(),
                _ => filtered.OrderBy(b => b.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            };
        }
    }

    private DateTime PurchasedAt(Book book)
        => AuthState.CurrentUser?.Library.FirstOrDefault(l => l.Uid == book.Uid)?.PurchasedAt ?? DateTime.MinValue;

    private DateTime? LastReadAt(Book book)
        => AuthState.CurrentUser?.Library.FirstOrDefault(l => l.Uid == book.Uid)?.LastReadAt;

    private void OnSearchInput(ChangeEventArgs e) => _searchTerm = e.Value?.ToString() ?? "";

    private void OnSortChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<SortMode>(e.Value?.ToString(), out var mode))
            _sortMode = mode;
    }

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += OnAuthChanged;
        await LoadIfReadyAsync();
    }

    private async void OnAuthChanged()
    {
        await LoadIfReadyAsync();
        StateHasChanged();
    }

    private async Task LoadIfReadyAsync()
    {
        if (AuthState.IsInitializing || !AuthState.IsAuthenticated) return;
        if (AuthState.CurrentUser is null) return;

        await LoadMyLibraryAsync();
    }

    private async Task LoadMyLibraryAsync()
    {
        _error = null;

        if (LibraryCache.TryGetMyLibrary(out var cached))
        {
            _myLibraryBooks = cached;
            _loading = false;
            return;
        }

        _loading = true;
        try
        {
            _myLibraryBooks = await AppService.GetMyLibraryBooks();
            LibraryCache.SetMyLibrary(_myLibraryBooks);
        }
        catch (ApiUnavailableException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "Could not load your library. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnReadClick(Book book)
    {
        _readError = null;

        if (book.Documents.Count == 0)
        {
            _readError = "This book doesn't have a readable document yet.";
            return;
        }

        if (book.Documents.Count == 1)
        {
            Nav.NavigateTo($"/read/{book.Uid}/{book.Documents[0].Uid}");
            return;
        }

        _selectedBookUid = book.Uid;
        _selectedBookTitle = book.Title ?? "Untitled";
        _selectedBookDocs = book.Documents;
        _docListOpen = true;
    }

    private void OnDocumentSelected(BookDocs doc)
        => Nav.NavigateTo($"/read/{_selectedBookUid}/{doc.Uid}");

    private bool IsFavorite(string bookUid)
        => AuthState.CurrentUser?.Library.FirstOrDefault(l => l.Uid == bookUid)?.IsFavorite ?? false;

    private async Task OnFavoriteToggle(string bookUid, bool isFavorite)
    {
        await AppService.SetFavorite(bookUid, isFavorite);
        await AuthState.RefreshProfileAsync();
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthChanged;
    }
}
